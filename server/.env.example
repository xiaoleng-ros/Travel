# 服务器端口
PORT=3001

# JWT 密钥（必须为32位以上的随机字符串）
# 生成命令: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-minimum-32-characters

# 默认管理员初始密码（未设置时首次启动会随机生成并打印在控制台）
# ADMIN_INITIAL_PASSWORD=ChangeMe@123!

# 对象存储凭证加密密钥（未设置时回退使用 JWT_SECRET）
# 注意：修改此密钥会导致已保存的存储凭证无法解密
# STORAGE_ENCRYPTION_KEY=your-32-char-storage-encryption-key

# 前端域名（用于 CORS 配置，多个域名用逗号分隔）
FRONTEND_URL=http://localhost:5173

# 环境模式
NODE_ENV=development
